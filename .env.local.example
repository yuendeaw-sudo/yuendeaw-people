# Supabase — project "yuendeaw people" (สร้าง project ใหม่แยกต่างหาก)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY

# Service role — server-side only. ห้าม expose ฝั่ง browser เด็ดขาด
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Restricted access (Phase 1) — Sponsor/Sales module locked to this owner email
NEXT_PUBLIC_OWNER_EMAIL=gap@standnextstage.com

# AI Workplace (Phase 3) — Claude API key (server-side only)
ANTHROPIC_API_KEY=sk-ant-...

# Notifications (Phase 4)
# Protects the cron scan route. Vercel Cron sends this as a Bearer token automatically.
CRON_SECRET=
# Optional email digests via Resend — leave blank to use in-app notifications only
RESEND_API_KEY=
RESEND_FROM=People OS <people@yuendeaw.com>
